# ────────────────────────────────────────────────────────────────
# The Spot — environment template.
# Copy to `.env` and fill in. Never commit real secrets.
# On Railway these are provided via the project / service variables.
# ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway provides this automatically).
DATABASE_URL="postgresql://user:password@localhost:5432/thespot?schema=public"

# Public site origin, used for absolute URLs / metadata.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ERP origin.
NEXT_PUBLIC_ERP_URL="http://localhost:3001"

# Secret used to sign login cookies. Set a long random value in production.
AUTH_SECRET="replace-with-a-long-random-secret"
