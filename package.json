{
  "name": "thespot",
  "version": "0.1.0",
  "private": true,
  "description": "The Spot — real estate platform for Uzbekistan (thespot.uz)",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "web",
    "erp",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "db:generate": "npm run db:generate --workspace @thespot/db",
    "db:migrate": "npm run db:migrate --workspace @thespot/db",
    "db:studio": "npm run db:studio --workspace @thespot/db"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
