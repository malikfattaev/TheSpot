// The Spot — data model.
// Rental marketplace: seekers browse listings, landlords publish them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Role is chosen by the user at registration and gates what they can do.
/// Owners and realtors may publish listings; see `canPublishListings`.
enum UserRole {
  SEEKER // looking for a place to rent
  OWNER // property owner, publishes listings
  REALTOR // estate agent, publishes listings
  ADMIN // platform staff
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PropertyType {
  APARTMENT
  ROOM
  HOUSE
  STUDIO
  COMMERCIAL
}

enum Currency {
  UZS
  USD
}

enum RentPeriod {
  MONTHLY // rent priced per month
  DAILY // rent priced per day (посуточно)
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?   @unique
  // Telegram handle (without the leading @), for the "write on Telegram"
  // button on listings. Optional — set from the profile page.
  telegramUsername String?
  passwordHash String
  fullName     String
  role         UserRole  @default(SEEKER)
  isVerified   Boolean   @default(false)
  listings     Listing[]
  favorites    Favorite[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([role])
}

model Listing {
  id           String         @id @default(cuid())
  title        String
  description  String
  type         PropertyType
  status       ListingStatus  @default(DRAFT)
  price        Decimal        @db.Decimal(12, 2)
  currency     Currency       @default(UZS)
  rentPeriod   RentPeriod     @default(MONTHLY)
  rooms        Int
  areaSqm      Float?
  floor        Int?
  // Location.
  city         String
  district     String?
  address      String?
  latitude     Float?
  longitude    Float?
  // Ownership.
  owner        User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId      String
  images       ListingImage[]
  favoritedBy  Favorite[]
  publishedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, city])
  @@index([ownerId])
}

model ListingImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  position  Int      @default(0)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())

  @@index([listingId])
}

/// A listing a seeker saved to revisit later. One row per (user, listing).
model Favorite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}
